{
  "name": "polychamber",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "build": "next build",
    "build:electron": "ELECTRON_BUILD=true next build && electron-builder",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "electron:compile": "tsc --project electron/tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.41.0",
    "next": "^15.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.3.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.4",
    "electron": "^36.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "so.polychamber.app",
    "productName": "Polychamber",
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      },
      {
        "from": ".next/static",
        "to": "app/.next/static"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
